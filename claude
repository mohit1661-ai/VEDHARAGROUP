    document.querySelectorAll('.section').forEach(s => s.classList.remove('on'));
    const t = document.getElementById(btn.dataset.s);
    if(t){ t.classList.add('on'); window.scrollTo({top:document.getElementById('tnav').offsetTop,behavior:'smooth'}); }
  });
});
</script>
</body>
</html>
